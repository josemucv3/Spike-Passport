# Passport API URL (with or without /v1)
PASSPORT_API_URL=https://api.paas.sandbox.co.passportfintech.com/v1

# OAuth2 client_credentials (PASSPORT_API_KEY = fallback for CLIENT_ID, SECRET_API_KEY = fallback for CLIENT_SECRET)
PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=
PASSPORT_API_KEY=
SECRET_API_KEY=

# Static data (bootstrap once per environment via Postman) - required for DYNAMIC QR
PASSPORT_CUSTOMER_ID=
PASSPORT_ACCOUNT_ID=
PASSPORT_KEY_ID=

# Server port
PORT=3001
